<persistence xmlns="https://jakarta.ee/xml/ns/persistence" version="3.0">

    <persistence-unit name="estudiantePU">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>logic.DatosEstudiante</class>
        <class>logic.Curso</class>
        <class>logic.LIKE_CURSO</class>
        <class>logic.MATCH_CURSO</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.sqlite.JDBC"/>

            <property name="jakarta.persistence.jdbc.url" value="jdbc:sqlite:C:/Users/ft842/IdeaProjects/WebApp/estudiante.sqlite"/>

            <property name="jakarta.persistence.jdbc.user" value=""/>
            <property name="jakarta.persistence.jdbc.password" value=""/>

            <property name="hibernate.dialect" value="org.hibernate.community.dialect.SQLiteDialect"/>

            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>


            <property name="hibernate.connection.pool_size" value="5"/>
        </properties>

    </persistence-unit>
</persistence>