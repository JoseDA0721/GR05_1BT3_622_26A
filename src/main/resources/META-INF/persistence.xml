<persistence xmlns="https://jakarta.ee/xml/ns/persistence" version="3.0">

    <persistence-unit name="redsaberesPU">
        <provider>org.hibernate.jpa.HibernatePersistenceProvider</provider>

        <class>org.redsaberes.model.Usuario</class>
        <class>org.redsaberes.model.Curso</class>
        <class>org.redsaberes.model.Modulo</class>
        <class>org.redsaberes.model.Leccion</class>
        <class>org.redsaberes.model.LikeCurso</class>
        <class>org.redsaberes.model.Inscripcion</class>
        <class>org.redsaberes.model.MatchCurso</class>
        <class>org.redsaberes.model.Resena</class>
        <class>org.redsaberes.model.Notificacion</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.sqlite.JDBC"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:sqlite:${user.home}/.redsaberes/redsaberes.db"/>
            <property name="jakarta.persistence.jdbc.user" value=""/>
            <property name="jakarta.persistence.jdbc.password" value=""/>
            <property name="hibernate.dialect" value="org.hibernate.community.dialect.SQLiteDialect"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>

            <property name="hibernate.connection.pool_size" value="5"/>
        </properties>

    </persistence-unit>
</persistence>